# Copy to .env and adjust. docker-compose reads this file.

# --- InfluxDB (Home Assistant data on the Synology) ---
INFLUX_HOST=192.168.10.237
INFLUX_PORT=8086
INFLUX_DATABASE=homeassistant
# Reads are unauthenticated on this instance; leave empty unless auth is on.
INFLUX_USERNAME=
INFLUX_PASSWORD=

# --- Dashboard behaviour ---
# Window (days) for the breakdown + fingerprint matching.
DASHBOARD_DAYS=7
# How often the snapshot is recomputed.
DASHBOARD_REFRESH_MINUTES=15
# Inside the container the store is always /data/fingerprints (see volume).
ENERGY_FINGERPRINT_DIR=/data/fingerprints

# --- Host bindings (used by docker-compose) ---
# Port published on the Synology.
DASHBOARD_PORT=8088
# Host folder holding the fingerprint JSONs (mounted read-only into the container).
FINGERPRINT_HOST_DIR=./fingerprints
