# Copy to .env and adjust. docker-compose reads this file.

# --- InfluxDB (Home Assistant data on the Synology) ---
INFLUX_HOST=192.168.10.237
INFLUX_PORT=8086
INFLUX_DATABASE=homeassistant
# Reads are unauthenticated on this instance; leave empty unless auth is on.
INFLUX_USERNAME=
INFLUX_PASSWORD=

# --- Dashboard behaviour ---
# Default period shown on load. One of: 1u 6u 24u 7d 30d 90d 1j.
# (Users pick any of these in the UI; this is just the startup default, and
# the one kept permanently warm in the cache.)
DASHBOARD_PERIOD=7d
# How often each period's snapshot is recomputed / its cache expires.
DASHBOARD_REFRESH_MINUTES=15
# InfluxDB HTTP read timeout (seconds).
INFLUX_TIMEOUT=90
# Inside the container these always point into the /data volume.
ENERGY_FINGERPRINT_DIR=/data/fingerprints
ENERGY_ASSIGNMENTS_FILE=/data/assignments.json

# --- Host bindings (used by docker-compose) ---
# Port published on the Synology.
DASHBOARD_PORT=8088
# Host folder for the writable data volume (fingerprints/ + assignments.json).
DATA_HOST_DIR=./data
